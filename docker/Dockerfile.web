FROM node:22-alpine AS build
ARG SUBPATH=notes
ARG VITE_BASE=/${SUBPATH}/
ENV VITE_BASE=${VITE_BASE}
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

FROM nginx:alpine
ARG SUBPATH=notes
COPY docker/nginx.subpath.template.conf /tmp/nginx.tmpl
RUN sed "s/__SUBPATH__/${SUBPATH}/g" /tmp/nginx.tmpl > /etc/nginx/conf.d/default.conf && rm /tmp/nginx.tmpl
COPY --from=build /app/dist /usr/share/nginx/html/${SUBPATH}
EXPOSE 80
