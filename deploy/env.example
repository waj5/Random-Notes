# 复制为 .env 后修改
POSTGRES_USER=notes
POSTGRES_PASSWORD=change-me
POSTGRES_DB=notes

# 浏览器访问路径为 http://get.fs-hck.top/<DEPLOY_SUBPATH>/
DEPLOY_SUBPATH=notes

# 宿主机映射端口；前面再放一层 Nginx 时通常反代到 127.0.0.1:8080
WEB_PORT=8080

SECRET_KEY=至少32位随机串
COOKIE_PATH_PREFIX=/notes
CORS_ALLOWED_ORIGINS=http://get.fs-hck.top,https://get.fs-hck.top
PUBLIC_BASE_URL=http://get.fs-hck.top/notes

ENFORCE_HTTPS=false
COOKIE_SECURE=false
APP_ENV=production
# 无短信网关时设为 false
REQUIRE_SMS_VERIFICATION=false

# 防刷：单 IP 每窗口内最大 API 请求数；0 表示关闭应用层全局限流
GLOBAL_API_RATE_LIMIT_MAX_REQUESTS=400
GLOBAL_API_RATE_LIMIT_WINDOW_SECONDS=60
REGISTER_RATE_LIMIT_MAX_ATTEMPTS=5
REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600
# 反代后建议填写公网域名，如 get.fs-hck.top（逗号分隔多个）；留空则不校验 Host
# TRUSTED_HOSTS=get.fs-hck.top
